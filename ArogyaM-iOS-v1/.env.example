# ArogyaM-iOS-v1 configuration — copy to ".env" and fill in your values.
# The .env file is git-ignored and bundled into the app as a resource at build time.

# Bearer token sent as: Authorization: Bearer <token>
# Must match the API key saved in arogyamandiram Settings → Health Data
BEARER_TOKEN=your-bearer-token-here

# Arogyamandiram base URL (no trailing slash)
# Local dev:   http://192.168.1.x:30000
# Production:  https://your-app.vercel.app
BASE_URL=http://192.168.1.194:30000

# Your arogyamandiram username (used in the push URL)
USERNAME=your-username-here
